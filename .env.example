# ==== Общие настройки ====
DATABASE_URL=sqlite:///./data/agregator.db
WEB_HOST=0.0.0.0
WEB_PORT=8000
# Простая защита портала (Basic Auth). Оставьте пустым, чтобы отключить.
PORTAL_USER=sales
PORTAL_PASSWORD=changeme

# Интервал автосбора в минутах (для встроенного планировщика)
COLLECT_INTERVAL_MINUTES=60

# ==== ЕИС zakupki.gov.ru (44-ФЗ / 223-ФЗ) ====
# Индивидуальный токен интеграции из личного кабинета ЕИС.
# Без него коллектор ЕИС отключён.
EIS_TOKEN=
EIS_ORG_INN=

# ==== Telegram ====
# Получить на https://my.telegram.org (API development tools)
TG_API_ID=
TG_API_HASH=
TG_SESSION=agregator
# Каналы/боты для чтения (через запятую)
TG_CHANNELS=@poshivrus

# ==== Швейные площадки (при необходимости — куки/токены авторизации) ====
POSHIVRUS_COOKIE=
SHVEINIK_COOKIE=

# ==== ЭТП (Сбер-АСТ, Росэлторг, Фабрикант и т.д.) ====
# Заполняются по мере получения доступов/договорённостей об API.
