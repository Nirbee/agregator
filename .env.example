# ==== Общие настройки ====
DATABASE_URL=sqlite:///./data/agregator.db
WEB_HOST=0.0.0.0
WEB_PORT=8000
# Защита портала (Basic Auth). Пусто = без защиты.
PORTAL_USER=sales
PORTAL_PASSWORD=changeme

# Интервал автосбора (минуты)
COLLECT_INTERVAL_MINUTES=60

# ==== Прокси для доступа к zakupki.gov.ru / ЕИС ====
# zakupki блокирует многие IP хостингов. Укажите РОССИЙСКИЙ прокси.
# Форматы:
#   http://user:pass@host:port
#   socks5://user:pass@host:port   (для SOCKS с авторизацией лучше http-прокси —
#                                    Chromium не поддерживает авторизацию SOCKS5)
# Спецсимволы в пароле кодируйте: @ -> %40, : -> %3A
PROXY_URL=

# ==== ЕИС zakupki.gov.ru (44-ФЗ) ====
EIS_TOKEN=
EIS_ORG_INN=

# ==== Telegram ====
TG_API_ID=
TG_API_HASH=
TG_SESSION=agregator
TG_CHANNELS=@poshivrus

# ==== Швейные площадки (куки авторизации при необходимости) ====
POSHIVRUS_COOKIE=
SHVEINIK_COOKIE=
